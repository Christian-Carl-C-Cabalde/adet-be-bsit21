{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",        
    "moduleResolution": "Bundler", 
    "allowImportingTsExtensions": false, 
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist"   
  },
  "exclude": ["node_modules"]
}